# ── Segurança ─────────────────────────────────────────────
# Nunca suba arquivos com senhas ou chaves!
.env
.env.local
.env.*.local

# ── Banco de dados local ───────────────────────────────────
*.db
*.sqlite
*.sqlite3
instance/

# ── Python cache ───────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
eggs/
*.egg

# ── Virtual environments ───────────────────────────────────
venv/
.venv/
env/
ENV/

# ── IDE / Editor ───────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~

# ── Sistema operacional ────────────────────────────────────
.DS_Store
.DS_Store?
Thumbs.db
desktop.ini

# ── Logs ───────────────────────────────────────────────────
*.log
/logs/
# Não ignorar o módulo Python de logs (blueprint da aplicação)
!/web/logs/

# ── Selenium / Chrome ──────────────────────────────────────
chromedriver
chromedriver.exe
